// Following code is from https://github.com/silq-lang/silq.git







def shor(n:!‚Ñï){
	if n%2=0 { return 2; }
	(x,y):=asPower(n);
	if y>1{ return x; }
	while true{
		a:=2+uniform(n sub 2);
		d:=gcdn(a,n);
		if d‚âÝ1{ return d; }
		r:=order(a,n);
		k:=gcdn(a^(r div 2)+1,n);
		if 1<k‚àßk<n { return k; }
	}
}

def asPower(n:!‚Ñï){
	y:=2;
	while 3^y‚â§n{
		(l,r):=(0,1);
		while r^y‚â§n{ r*=2; }
		while l+1‚âÝr{
			m:=(l+r) div 2;
			if m^y‚â§n { l=m; }
			else { r=m; }
		}
		if l^y=n{ return (l,y); }
		y+=1;
	}
	return (n,1);
}

def uniform(n:!‚Ñï){
	(k,l):=(0,1);
	while l‚â§n { k+=1, l*=2; }
	while true {
		x:=0:uint[k];
		for i in 0..k{ x[i]:=H(x[i]); }
		x:=measure(x) as !‚Ñï;
		if x<n{ return x; }
	}
}

// order-finding:
def log‚ÇÇ(x:!‚Ñù)‚áílog(x)/log(2);
def order(a:!‚Ñï,N:!‚Ñï){
	(n,m):=(0,1);
	while m<N { n+=2, m*=2; }
	b:=1:!‚Ñ§;
	while a^b%N‚âÝ1{
		def f(b:uint[n])lifted‚áípowm(a as uint[n],b,N);
		c:=candidates(estimatePhase(f)/2^n);
		for i in [0..c.length){
			if c[i]‚âÝ0‚àßa^c[i]%N=1{ b=c[i]; }
		}
	}
	return b coerce !‚Ñï;
}
def estimatePhase[n:!‚Ñï](f:uint[n] !‚Üílifted uint[n]):!‚Ñï{
	cand := 0:uint[n];
	for k in [0..n) { cand[k] := H(cand[k]); }
	measure(f(cand));
	cand := reverse(QFT[n])(cand);
	return measure(cand) as !‚Ñï;
}

def candidates(q:!‚Ñö){ // TODO: probably this can be improved
	res:=[]:!‚Ñ§[];
	r:=to_cfrac(q);
	while r.length‚âÝ0{
		res~=[from_cfrac(r)[1]];
		r=r[0..r.length-1];
	}
	return res;
}
def to_cfrac(q:!‚Ñö){
	if q=0{ return [0:!‚Ñ§]; }
	r:=[]:!‚Ñ§[];
	nq:=1/q;
	while nq‚âÝ0{
		nq=1/nq;
		p:=floor(nq);
		nq-=p;
		r~=[p];
	}
	return r;
}

def gcdn(a:!‚Ñï,b:!‚Ñï):!‚Ñï‚áígcd(a,b) coerce !‚Ñï;
def gcd(a:!‚Ñ§,b:!‚Ñ§):!‚Ñ§‚áíif a=0 then b else gcd(b%a,a);
def reduce(a:!‚Ñ§,b:!‚Ñ§){ d:=gcd(a,b); return (a div d,b div d); }
def add(x:!‚Ñ§^2,y:!‚Ñ§^2)‚áíreduce(x[0]¬∑y[1]+x[1]¬∑y[0],x[1]¬∑y[1]);
def inv(a:!‚Ñ§,b:!‚Ñ§)‚áí(b,a);
def from_cfrac(r:!‚Ñ§[]):(!‚Ñ§√ó!‚Ñ§)‚áíif r.length>1 then add((r[0],1),inv(from_cfrac(r[1..r.length]))) else (r[0],1);

def QFT[n:!‚Ñï](œà: uint[n])mfree: uint[n]{
	for k in [0..n div 2){
		(œà[k],œà[n-k-1]) := (œà[n-k-1],œà[k]);
	}
	for k in [0..n){
		œà[k] := H(œà[k]);
		for l in [k+1..n){
			if œà[l] && œà[k]{
				phase(2¬∑œÄ ¬∑ 2^(k-l-1));
			}
		}
	}
	return œà;
}

def powm[n:!‚Ñï,m:!‚Ñï](a:uint[n],b:uint[m],N:!‚Ñï)lifted: uint[n]{
	(r,x):=(1:uint[2*n], a);

	// Expand x to a 2n-qubit integer
	x_expanded_vec := (x as B^n)~vector(n, 0:B);
	x := x_expanded_vec coerce uint[2*n];

	for i in 0..m{
		if b[i]{
			r=r¬∑x%N;
		}
		x=x¬∑x%N;
	}

	// Truncate r to an n-qubit integer
	r_vec := r as B^(2*n);
	for i in [0..n) {
		r_vec~(r_top_qubit,) := r_vec;
	}
	return r_vec coerce uint[n];
}


